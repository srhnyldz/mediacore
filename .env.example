APP_NAME=YLZ MediaCore API
API_PREFIX=/api/v1
API_HOST=0.0.0.0
API_PORT=8000
REDIS_URL=redis://redis:6379/0
REDIS_SOCKET_TIMEOUT_SECONDS=2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
DOWNLOAD_ROOT=/tmp/downloads
CELERY_DOWNLOAD_QUEUE=download
CELERY_CONVERT_QUEUE=convert
CELERY_RESULT_TTL_SECONDS=86400
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=900
CELERY_TASK_TIME_LIMIT_SECONDS=960
CELERY_WORKER_MAX_TASKS_PER_CHILD=50
CELERY_VISIBILITY_TIMEOUT_SECONDS=1800
CLEANUP_MAX_AGE_HOURS=24
CLEANUP_BATCH_LIMIT=100
DOWNLOAD_REQUEST_RATE_LIMIT=10
DOWNLOAD_REQUEST_RATE_WINDOW_SECONDS=60
